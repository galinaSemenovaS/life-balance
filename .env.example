# Database (Neon PostgreSQL)
# DATABASE_URL — pooled (хост с -pooler), для приложения
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL — direct (без pooler), только для prisma db push локально
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Локально:
AUTH_URL="http://localhost:3000"

# Production (Vercel) — добавить в Environment Variables:
# AUTH_URL="https://life-balance-murex.vercel.app"
# trustHost: true уже включён — на Vercel AUTH_URL можно не задавать (берётся VERCEL_URL)

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Web Push (generate: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# Cron (GitHub Actions или cron-job.org → /api/cron/send-reminders)
CRON_SECRET="random-secret-string"
CRON_WINDOW_MINUTES="1"
