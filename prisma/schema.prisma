generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String?                 @unique
  emailVerified          DateTime?
  image                  String?
  onboarded              Boolean                 @default(false)
  accounts               Account[]
  sessions               Session[]
  spheres                Sphere[]
  assessments            Assessment[]
  goals                  Goal[]
  habits                 Habit[]
  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model Sphere {
  id          String        @id @default(cuid())
  userId      String
  name        String
  defaultName String
  color       String
  sortOrder   Int
  isPriority  Boolean       @default(false)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals       Goal[]
  habits      Habit[]
  scores      SphereScore[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([userId, sortOrder])
  @@index([userId])
}

model Assessment {
  id        String        @id @default(cuid())
  userId    String
  note      String?
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scores    SphereScore[]
  createdAt DateTime      @default(now())

  @@index([userId, createdAt])
}

model SphereScore {
  id           String     @id @default(cuid())
  assessmentId String
  sphereId     String
  score        Int
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  sphere       Sphere     @relation(fields: [sphereId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, sphereId])
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  sphereId    String
  title       String
  description String?
  status      GoalStatus @default(ACTIVE)
  targetScore Int?
  deadline    DateTime?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sphere      Sphere     @relation(fields: [sphereId], references: [id], onDelete: Cascade)
  planSteps   PlanStep[]
  habits      Habit[]
  tasks       Task[]
  aiDrafts    AiPlanDraft[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId, status])
}

model PlanStep {
  id        String    @id @default(cuid())
  goalId    String
  title     String
  order     Int
  startDate DateTime?
  endDate   DateTime?
  goal      Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

enum TaskStatus {
  PENDING
  COMPLETED
}

model Task {
  id              String           @id @default(cuid())
  goalId          String
  planStepId      String?
  title           String
  dueDate         DateTime?
  recurrence      Json?
  reminderTime    String?
  reminderEnabled Boolean          @default(false)
  status          TaskStatus       @default(PENDING)
  goal       Goal             @relation(fields: [goalId], references: [id], onDelete: Cascade)
  planStep   PlanStep?        @relation(fields: [planStepId], references: [id], onDelete: SetNull)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([goalId, dueDate])
}

enum HabitFrequency {
  DAILY
  WEEKLY
  CUSTOM
}

model Habit {
  id           String         @id @default(cuid())
  userId       String
  sphereId     String?
  goalId       String?
  title        String
  frequency    HabitFrequency @default(DAILY)
  schedule     Json?
  reminderTime    String?
  reminderEnabled Boolean        @default(false)
  endDate         DateTime?
  isActive        Boolean        @default(true)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sphere       Sphere?        @relation(fields: [sphereId], references: [id], onDelete: SetNull)
  goal         Goal?          @relation(fields: [goalId], references: [id], onDelete: SetNull)
  logs         HabitLog[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId, isActive])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime @db.Date
  completed Boolean  @default(true)
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model NotificationPreference {
  id                 String  @id @default(cuid())
  userId             String  @unique
  wheelReviewDay     Int     @default(0)
  wheelReviewTime    String  @default("10:00")
  habitsEnabled      Boolean @default(true)
  wheelReviewEnabled Boolean @default(true)
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiPlanDraft {
  id        String   @id @default(cuid())
  goalId    String
  prompt    String   @db.Text
  response  String?  @db.Text
  status    String   @default("pending")
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
